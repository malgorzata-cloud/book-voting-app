<!DOCTYPE html>
<html>
<head>
    <title>Voting Results</title>
    <style>
        body {
            background-color: #1a1a1a;
            color: #ddd;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
            text-align: center;
        }
        h1 {
            color: #9b59b6;
            margin-bottom: 20px;
        }
        table {
            margin: 0 auto;
            border-collapse: collapse;
            width: 60%;
        }
        th, td {
            padding: 10px 15px;
            border: 1px solid #444;
        }
        th {
            background-color: #2c2c2c;
            color: #9b59b6;
        }
        td {
            background-color: #2c2c2c;
        }
        pre {
            text-align: left;
            background-color: #2c2c2c;
            padding: 15px;
            border-radius: 8px;
            margin: 20px auto;
            width: 80%;
            overflow-x: auto;
            color: #9b59b6;
        }
    </style>
</head>
<body>
    <h1>Voting Results</h1>

    <% if (sorted.length === 0) { %>
        <p>No votes yet.</p>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Book</th>
                    <th>Points</th>
                </tr>
            </thead>
            <tbody>
                <% sorted.forEach(([title, points]) => { %>
                    <tr>
                        <td><%= title %></td>
                        <td><%= points %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <h2>Raw Votes Data</h2>
        <pre><%= JSON.stringify(votes, null, 2) %></pre>
    <% } %>

    <a href="/admin">Back to Admin</a>
</body>
</html>
