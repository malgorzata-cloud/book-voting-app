<!DOCTYPE html>
<html>
<head>
    <title>Admin - Fantasy Book Voting</title>
    <style>
        body {
            background-color: #1a1a1a;
            color: #ddd;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            text-align: center;
            padding: 30px;
        }
        h1 {
            color: #9b59b6;
            margin-bottom: 20px;
        }
        form {
            background-color: #2c2c2c;
            padding: 20px;
            display: inline-block;
            border-radius: 10px;
            margin-bottom: 20px;
        }
        input[type="password"], button {
            display: block;
            margin: 15px auto;
            padding: 10px;
            border-radius: 5px;
            border: none;
        }
        button {
            background-color: #9b59b6;
            color: #fff;
            cursor: pointer;
            transition: background 0.3s;
        }
        button:hover {
            background-color: #7a3490;
        }
        a {
            color: #9b59b6;
            text-decoration: none;
            display: inline-block;
            margin-top: 10px;
        }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <h1>Admin Page - Fantasy Book Club</h1>

    <% if (message) { %>
        <p style="color: lightgreen; font-weight: bold;"><%= message %></p>
    <% } %>

    <!-- RESET FORM -->
    <form action="/admin/reset" method="POST">
        <label>
            Admin Password:
            <input type="password" name="password" required>
        </label>
        <button type="submit">Reset All Votes</button>
    </form>
    <!-- RESULTS LINK -->
    <h2>View Results</h2>
    <form action="/admin/results" method="GET">
        <label>
            Admin Password:
            <input type="password" name="password" required>
        </label>
        <label>
            Month (YYYY-MM):
            <input type="text" name="month" placeholder="Leave blank for current month">
        </label>
        <button type="submit">View Results</button>
    </form>

    <!-- RESULTS LINK -->
